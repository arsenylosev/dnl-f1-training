{
    "_comment": "Foundation-1 (stable-audio-open-1.0) architecture at 3s crop (44100 × 3 = 132300 samples). Matches pre_encode.py default --sample-size and Vertex SAMPLE_SIZE. CLAP path is a placeholder; runtime images mount real weights.",
    "model_type": "diffusion_cond",
    "sample_size": 132300,
    "sample_rate": 44100,
    "audio_channels": 2,
    "model": {
        "pretransform": {
            "type": "autoencoder",
            "iterate_batch": true,
            "config": {
                "encoder": {
                    "type": "dac",
                    "config": {
                        "in_channels": 2,
                        "latent_dim": 128,
                        "d_model": 128,
                        "strides": [4, 4, 8, 8]
                    }
                },
                "decoder": {
                    "type": "dac",
                    "config": {
                        "out_channels": 2,
                        "latent_dim": 64,
                        "channels": 1536,
                        "rates": [8, 8, 4, 4]
                    }
                },
                "bottleneck": {
                    "type": "vae"
                },
                "latent_dim": 64,
                "downsampling_ratio": 1024,
                "io_channels": 2
            }
        },
        "conditioning": {
            "configs": [
                {
                    "id": "prompt",
                    "type": "clap_text",
                    "config": {
                        "audio_model_type": "HTSAT-base",
                        "enable_fusion": true,
                        "clap_ckpt_path": "/path/to/clap.ckpt",
                        "use_text_features": true,
                        "feature_layer_ix": -2
                    }
                },
                {
                    "id": "seconds_start",
                    "type": "int",
                    "config": {
                        "min_val": 0,
                        "max_val": 512
                    }
                },
                {
                    "id": "seconds_total",
                    "type": "int",
                    "config": {
                        "min_val": 0,
                        "max_val": 512
                    }
                }
            ],
            "cond_dim": 768
        },
        "diffusion": {
            "type": "adp_cfg_1d",
            "cross_attention_cond_ids": ["prompt", "seconds_start", "seconds_total"],
            "config": {
                "in_channels": 64,
                "context_embedding_features": 768,
                "context_embedding_max_length": 79,
                "channels": 256,
                "resnet_groups": 16,
                "kernel_multiplier_downsample": 2,
                "multipliers": [4, 4, 4, 5, 5],
                "factors": [1, 2, 2, 4],
                "num_blocks": [2, 2, 2, 2],
                "attentions": [1, 3, 3, 3, 3],
                "attention_heads": 16,
                "attention_multiplier": 4,
                "use_nearest_upsample": false,
                "use_skip_scale": true,
                "use_context_time": true
            }
        },
        "io_channels": 64
    },
    "training": {
        "pre_encoded": true,
        "learning_rate": 4e-5,
        "demo": {
            "demo_every": 2000,
            "demo_steps": 250,
            "num_demos": 4,
            "demo_cond": [
                {"prompt": "An analog synth pad rich in harmonics, creating an immersive and dynamic soundscape.", "seconds_start": 0, "seconds_total": 3},
                {"prompt": "An analog synth bass dry, fat, minimalist with a transient-focused reverb effect.", "seconds_start": 0, "seconds_total": 3},
                {"prompt": "A sharp, crisp-edged percussive sound, resonant and dynamic, sets the stage for a rhythmic pattern in a trance track.", "seconds_start": 0, "seconds_total": 3},
                {"prompt": "A bold-toned, sharp-sounding, analog-synthesized lead with a 80s-inspired analog quality is present.", "seconds_start": 0, "seconds_total": 3}
            ],
            "demo_cfg_scales": [3, 6, 9]
        }
    }
}
