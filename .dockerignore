# =============================================================================
# .dockerignore — Keep Docker build context lean
# =============================================================================

# Git history (not needed in container)
.git/
.gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/
/opt/

# Model weights (large binary files — mount from GCS at runtime instead)
# NOTE: Use /models/ (root-anchored). A bare "models/" matches ANY path named
# models, including stable_audio_tools/models/ — which would omit the package.
*.ckpt
*.safetensors
*.pt
*.pth
*.bin
*.h5
*.hdf5
/models/

# Pre-encoded latents (large — stored in GCS)
# NOTE: /data/ is root-anchored. Bare "data/" also matched stable_audio_tools/data/.
pre_encoded_3s/
latents/
/data/

# Logs and checkpoints
*.log
logs/
checkpoints/
wandb/
clearml_cache/
mlruns/
outputs/

# Jupyter notebooks (not needed in training container)
*.ipynb
.ipynb_checkpoints/

# Documentation
docs/
*.md
!README.md

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
*.xml

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
scratch/
